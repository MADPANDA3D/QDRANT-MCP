# Required for hosted MAD MCP Portal access. Broker sends this value in X-MADPANDA-PORTAL-GRANT.
MCP_PORTAL_GRANT_TOKEN=

# Required unless using QDRANT_LOCAL_PATH.
QDRANT_URL=

# Required for secured remote Qdrant instances.
QDRANT_API_KEY=

# Optional default collection. Hosted BYO-Qdrant users may provide X-Collection-Name instead.
COLLECTION_NAME=

# Optional vector name override.
QDRANT_VECTOR_NAME=

# Optional local Qdrant path. Do not set with QDRANT_URL.
QDRANT_LOCAL_PATH=

# Embeddings. Use fastembed for local embeddings or openai for OpenAI-compatible embeddings.
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_VECTOR_SIZE=
EMBEDDING_VERSION=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG=
OPENAI_PROJECT=

# Hosted request override mode.
MCP_ALLOW_REQUEST_OVERRIDES=true
MCP_REQUIRE_REQUEST_QDRANT_URL=true
MCP_REQUIRE_REQUEST_QDRANT_API_KEY=true
MCP_REQUIRE_REQUEST_COLLECTION=false
MCP_DISABLE_DEFAULT_QDRANT_FALLBACK=true
MCP_DISABLE_DEFAULT_EMBEDDING_FALLBACK=false
MCP_QDRANT_HOST_ALLOWLIST=*.qdrant.io

# Broker/header names.
MCP_PORTAL_GRANT_HEADER=x-madpanda-portal-grant
MCP_QDRANT_URL_HEADER=x-qdrant-url
MCP_QDRANT_API_KEY_HEADER=x-qdrant-api-key
MCP_COLLECTION_NAME_HEADER=x-collection-name
MCP_QDRANT_VECTOR_NAME_HEADER=x-qdrant-vector-name
MCP_EMBEDDING_PROVIDER_HEADER=x-embedding-provider
MCP_EMBEDDING_MODEL_HEADER=x-embedding-model
MCP_EMBEDDING_VECTOR_SIZE_HEADER=x-embedding-vector-size
MCP_OPENAI_API_KEY_HEADER=x-openai-api-key
MCP_OPENAI_BASE_URL_HEADER=x-openai-base-url
MCP_OPENAI_ORG_HEADER=x-openai-org
MCP_OPENAI_PROJECT_HEADER=x-openai-project

# Tool safety and limits.
MCP_ADMIN_TOOLS_ENABLED=false
MCP_MUTATIONS_REQUIRE_ADMIN=false
MCP_MAX_BATCH_SIZE=500
MCP_MAX_POINT_IDS=500
MCP_STRICT_PARAMS=false
MCP_MAX_TEXT_LENGTH=8000
QDRANT_READ_ONLY=false
QDRANT_ALLOW_ARBITRARY_FILTER=false
QDRANT_SEARCH_LIMIT=10

# Query token/cost controls.
MCP_QUERY_EMBEDDING_CACHE_SIZE=256
MCP_QUERY_EMBEDDING_CACHE_TTL_SECONDS=3600

# Memory maintenance.
MCP_DEDUPE_ACTION=update
MCP_INGEST_VALIDATION_MODE=allow
MCP_QUARANTINE_COLLECTION=jarvis-quarantine
MCP_HEALTH_CHECK_COLLECTION=
MCP_SHORT_TERM_COLLECTION=jarvis-short-term
MCP_SHORT_TERM_TTL_DAYS=7

# Textbook ingest limits and job persistence.
MCP_TEXTBOOK_MAX_FILE_BYTES=104857600
MCP_TEXTBOOK_MAX_PAGES=1000
MCP_TEXTBOOK_MAX_EXTRACTED_CHARS=3000000
MCP_TEXTBOOK_MAX_CHUNKS=20000
MCP_TEXTBOOK_OCR_LOW_TEXT_THRESHOLD_CHARS=120
MCP_TEXTBOOK_OCR_MIN_COVERAGE_RATIO=0.85
MCP_TEXTBOOK_OCR_MAX_PAGES=120
MCP_TEXTBOOK_OCR_MAX_PAGE_RATIO=0.30
MCP_TEXTBOOK_JOB_TIMEOUT_SECONDS=2700
MCP_TEXTBOOK_EMBED_BATCH_SIZE=32
MCP_TEXTBOOK_UPSERT_BATCH_SIZE=64
MCP_TEXTBOOK_MAX_CONCURRENCY=2
MCP_TEXTBOOK_JOB_STATE_DIR=/tmp/mcp-server-qdrant/jobs
MCP_TEXTBOOK_JOB_STATE_RETENTION_HOURS=168

# Runtime.
MCP_SERVER_VERSION=
FASTMCP_SERVER_HOST=0.0.0.0
FASTMCP_SERVER_PORT=8000
FORWARDED_ALLOW_IPS=
